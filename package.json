{
  "name": "f95_tracker",
  "version": "1.0.0",
  "description": "Windows desktop tracker for F95Zone game threads and local archives.",
  "main": "src/main/main.js",
  "scripts": {
    "start": "electron .",
    "postinstall": "node scripts/sync-7zip.js",
    "test": "node test/run.js",
    "build": "electron-builder --win portable"
  },
  "keywords": [
    "electron",
    "f95zone",
    "desktop"
  ],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "7zip-bin": "^5.2.0",
    "cheerio": "^1.2.0",
    "chokidar": "^5.0.0",
    "sql.js": "^1.14.1"
  },
  "devDependencies": {
    "electron": "^41.1.1",
    "electron-builder": "^26.0.12"
  },
  "build": {
    "appId": "com.f95tracker.app",
    "productName": "F95 Tracker",
    "asar": true,
    "files": [
      "src/**/*",
      "scripts/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "resources/icon.ico",
        "to": "icon.ico"
      },
      {
        "from": "resources/tools",
        "to": "tools",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "icon": "resources/icon.ico",
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "portable": {
      "artifactName": "${productName}-${version}-portable-${arch}.${ext}"
    }
  }
}
